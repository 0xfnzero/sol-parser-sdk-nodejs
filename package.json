{
  "name": "sol-parser-sdk-ts",
  "version": "0.3.0",
  "description": "Solana DEX 日志与交易事件解析（TypeScript 实现，本仓库自洽）",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "check:dex-events": "node scripts/check-dex-event-parity.mjs",
    "verify:discriminators": "node scripts/verify-program-log-discriminators.mjs",
    "check:json-utils": "node scripts/check-json-utils.mjs",
    "check:migration": "npm run build && npm run check:dex-events && npm run verify:discriminators && npm run check:json-utils"
  },
  "keywords": ["solana", "dex", "parser", "pumpfun", "raydium"],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.4",
    "@triton-one/yellowstone-grpc": "^1.0.0",
    "bs58": "^6.0.0"
  }
}
